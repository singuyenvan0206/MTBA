# ==========================================
# SERVER CONFIG
# ==========================================
PORT=3000

# ==========================================
# DATABASE CONNECTION (MySQL / MariaDB)
# ==========================================
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?sslaccept=strict
DATABASE_URL="mysql://username:password@localhost:3306/db_name"

# ==========================================
# EMAIL / NODEMAILER CONFIG (Gmail or SMTP)
# ==========================================
MAIL_USER="your_email@gmail.com"
MAIL_PASS="your_gmail_app_password"
MAIL_FROM="Hệ thống Đặt vé <your_email@gmail.com>"

# ==========================================
# OTP CONFIG
# ==========================================
OTP_EXPIRES_MINUTES=5

# ==========================================
# FIREBASE CONFIG (For OTP/SMS authentication)
# ==========================================
FIREBASE_API_KEY="your_firebase_api_key"
FIREBASE_AUTH_DOMAIN="your_firebase_auth_domain.firebaseapp.com"
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_STORAGE_BUCKET="your_firebase_storage_bucket.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="your_messaging_sender_id"
FIREBASE_APP_ID="your_firebase_app_id"

# ==========================================
# SECURITY PEPPER (Bcrypt Salt/Pepper)
# ==========================================
# Generate a random, long, secure string for password hashing (e.g. 64-char hex string)
PASSWORD_PEPPER="generate_a_random_64_character_hex_string"

# ==========================================
# SEPAY CONFIG (Cổng thanh toán VietQR)
# ==========================================
SEPAY_BANK_ID="your_bank_id_e_g_TPB"
SEPAY_ACCOUNT_NO="your_bank_account_number"
SEPAY_ACCOUNT_NAME="YOUR_FULL_NAME"
SEPAY_API_TOKEN="your_sepay_api_access_token"

